                        if name == plr.Name then
                            child.BackgroundColor3 = Colors.RedDark
                        else
                            child.BackgroundColor3 = Colors.DarkerBg
                        end
                    end
                end
                
                -- AUTO VIEW: terus start spectate
                startSpectate(plr)
                ShowNotification("Auto View", "Now watching: " .. plr.DisplayName, "success")
            end)
            
            yPos = yPos + 27
        end
        
        playerScrollFrame.CanvasSize = UDim2.new(0, 0, 0, yPos + 10)
    end
    
    -- Button actions
    specBtn.MouseButton1Click:Connect(function()
        if not selectedPlayer then
            ShowNotification("Error", "Select a player first!", "error")
            return
        end
        startSpectate(selectedPlayer)
    end)
    
    teleBtn.MouseButton1Click:Connect(function()
        if not selectedPlayer then
            ShowNotification("Error", "Select a player first!", "error")
            return
        end
        teleportToPlayer(selectedPlayer)
    end)
    
    followBtn.MouseButton1Click:Connect(function()
        if not selectedPlayer then
            ShowNotification("Error", "Select a player first!", "error")
            return
        end
        if followActive then
            stopFollow()
            followBtn.Text = "FOLLOW ON"
            followBtn.BackgroundColor3 = Colors.DarkerBg
        else
            startFollow(selectedPlayer)
            followBtn.Text = "FOLLOW OFF"
            followBtn.BackgroundColor3 = Colors.RedDark
        end
    end)
    
    stopBtn.MouseButton1Click:Connect(function()
        stopAllSpectate()
        followBtn.Text = "FOLLOW ON"
        followBtn.BackgroundColor3 = Colors.DarkerBg
    end)
    
    -- Events
    Players.PlayerAdded:Connect(refreshPopupPlayerList)
    Players.PlayerRemoving:Connect(function()
        if selectedPlayer and not selectedPlayer.Parent then
            selectedPlayer = nil
            selectedLabel.Text = "No player selected"
        end
        refreshPopupPlayerList()
    end)
    
    refreshPopupPlayerList()
    
    -- Gradient rotation loop untuk spectate window
    task.spawn(function()
        while spectateWindow and spectateWindow.Parent do
            task.wait(0.05)
            if specBgGradient then
                specBgGradient.Rotation = (specBgGradient.Rotation + 3) % 360
            end
            if specStrokeGradient then
                specStrokeGradient.Rotation = (specStrokeGradient.Rotation + 4) % 360
            end
        end
    end)
end

