local function createDotEffect(parent, dotTable)
    local container = Instance.new("Frame", parent)
    container.Name = "DotBackground"
    container.Size = UDim2.new(1, 0, 1, 0)
    container.Position = UDim2.new(0, 0, 0, 0)
    container.BackgroundTransparency = 1
    container.ZIndex = 0
    
    for i = 1, 40 do
        local dot = Instance.new("Frame")
        dot.Size = UDim2.new(0, math.random(2, 4), 0, math.random(2, 4))
        dot.Position = UDim2.new(math.random(), 0, math.random(), 0)
        dot.BackgroundColor3 = GradientColors.LighterRed
        dot.BackgroundTransparency = math.random(40, 80) / 100
        dot.BorderSizePixel = 0
        dot.Parent = container
        dot.ZIndex = 0
        
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(1, 0)
        corner.Parent = dot
        
        dot:SetAttribute("SpeedX", (math.random() - 0.5) * 0.015)
        dot:SetAttribute("SpeedY", (math.random() - 0.5) * 0.015)
        dot:SetAttribute("Pulse", math.random() * 2)
        
        table.insert(dotTable, dot)
    end
    
    return container
end

local function updateDots(dotTable, dt)
    for _, dot in pairs(dotTable) do
        local sx = dot:GetAttribute("SpeedX") or 0.008
        local sy = dot:GetAttribute("SpeedY") or 0.008
        local pulse = dot:GetAttribute("Pulse") or 1
        
        local newX = (dot.Position.X.Scale + sx * dt * 30) % 1
        local newY = (dot.Position.Y.Scale + sy * dt * 30) % 1
        dot.Position = UDim2.new(newX, 0, newY, 0)
        dot.BackgroundTransparency = math.sin(tick() * 2 + pulse) * 0.15 + 0.45
    end
end

