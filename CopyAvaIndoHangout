-- Function to get player list
local function getPlayerList()
    local players = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            table.insert(players, player.Name)
        end
    end
    if #players > 0 then
        return players
    else
        return {"No players"}
    end
end

