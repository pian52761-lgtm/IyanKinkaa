-- Teleport Button
PlayerTab:Button({
    Title = "Teleport to Player",
    Desc = "Teleport to selected player",
    Callback = function()
        local targetPlayer = Players:FindFirstChild(selectedPlayer)
        if targetPlayer and targetPlayer ~= LocalPlayer and targetPlayer.Character and LocalPlayer.Character then
            local targetHRP = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
            local localHRP = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if targetHRP and localHRP then
                localHRP.CFrame = targetHRP.CFrame
                Window:Notify({
                    Title = "Teleported",
                    Desc = "Moved to " .. targetPlayer.Name,
                    Time = 3
                })
            end
        else
            Window:Notify({
                Title = "Error",
                Desc = "Cannot teleport to target.",
                Time = 3
            })
        end
    end
})

-- Spectate Button
local isViewing = false
local lastCameraSubject = nil

PlayerTab:Button({
    Title = "View / Unview Player",
    Desc = "Spectate selected player camera",
    Callback = function()
        if isViewing then
            -- Stop spectating
            if lastCameraSubject then
                Camera.CameraSubject = lastCameraSubject
            end
            isViewing = false
            Window:Notify({
                Title = "Unviewed",
                Desc = "Camera returned to normal.",
                Time = 3
            })
        else
            -- Start spectating
            if not selectedPlayer or selectedPlayer == "No players" then
                Window:Notify({
                    Title = "View Error",
                    Desc = "Select a valid target.",
                    Time = 3
                })
                return
            end
            
            local targetPlayer = Players:FindFirstChild(selectedPlayer)
            if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChildOfClass("Humanoid") then
                lastCameraSubject = Camera.CameraSubject
                Camera.CameraSubject = targetPlayer.Character.Humanoid
                isViewing = true
                Window:Notify({
                    Title = "Viewing",
                    Desc = "Now watching " .. targetPlayer.Name,
                    Time = 3
                })
            else
                Window:Notify({
                    Title = "View Error",
                    Desc = "Target not found or has no character.",
                    Time = 3
                })
            end
        end
    end
})

