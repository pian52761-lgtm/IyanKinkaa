-- ================= KEY SYSTEM FUNCTIONS =================
local function xor_encrypt(data, key)
    local encrypted = ""
    for i = 1, #data do
        local char_code = string.byte(data, i)
        local key_char = string.byte(key, ((i - 1) % #key) + 1)
        encrypted = encrypted .. string.char(bit32.bxor(char_code, key_char))
    end
    return encrypted
end

local function xor_decrypt(encrypted, key)
    return xor_encrypt(encrypted, key)
end

local function generate_hwid()
    local hwid_parts = {}
    
    -- Get executor HWID
    local success, hwid = pcall(function()
        if syn and syn.crypt then
            return syn.crypt.hwid()
        elseif getexecutorname then
            return getexecutorname() .. os.time()
        else
            return tostring(os.time())
        end
    end)
    
    if success and hwid then
        table.insert(hwid_parts, tostring(hwid))
    end
    
    -- Get machine info
    local success, info = pcall(function()
        return HttpService:JSONEncode({
            os = tostring(os.time()),
            guid = tostring(HttpService:GenerateGUID(false))
        })
    end)
    
    if success and info then
        table.insert(hwid_parts, info)
    end
    
    local raw = table.concat(hwid_parts, "|")
    return HttpService:SHA256(raw)
end

local function load_license()
    local success, data = pcall(function()
        return readfile(KEY_CONFIG.license_file)
    end)
    
    if success and data then
        local decrypted = xor_decrypt(data, KEY_CONFIG.encryption_key)
        return HttpService:JSONDecode(decrypted)
    end
    return nil
end

local function save_license(license_data)
    local json = HttpService:JSONEncode(license_data)
    local encrypted = xor_encrypt(json, KEY_CONFIG.encryption_key)
    writefile(KEY_CONFIG.license_file, encrypted)
end

local function validate_license()
    local license = load_license()
    if not license then
        return false, "No license found"
    end
    
    local hwid = generate_hwid()
    
    -- Check HWID
    if license.hwid ~= hwid then
        return false, "HWID mismatch"
    end
    
    -- Check expiry
    if os.time() > license.expiry then
        return false, "License expired"
    end
    
    -- Check activations
    if license.activations > license.max_activations then
        return false, "Max activations reached"
    end
    
    return true, "License valid"
end

local function activate_trial()
    local hwid = generate_hwid()
    local trial_data = {
        type = "trial",
        created = os.time(),
        expiry = os.time() + (KEY_CONFIG.trial_days * 86400),
        hwid = hwid,
        activations = 1,
        max_activations = KEY_CONFIG.max_activations,
        features = {
            jump = true
        }
    }
    save_license(trial_data)
    return trial_data
end

local function activate_key(key)
    -- Validasi key langsung tanpa hash
    local key_trimmed = string.gsub(key, "%s+", "") -- Remove whitespace
    
    -- Premium key: IYANXCODE
    -- Trial key: IYANKINKA
    local key_data = nil
    
    if key_trimmed == "IYANXCODE" then
        key_data = {
            type = "premium",
            duration = 365
        }
    elseif key_trimmed == "IYANKINKA" then
        key_data = {
            type = "trial",
            duration = 7
        }
    end
    
    if key_data then
        local hwid = generate_hwid()
        local license_data = {
            type = key_data.type,
            created = os.time(),
            expiry = os.time() + (key_data.duration * 86400),
            hwid = hwid,
            activations = 1,
            max_activations = KEY_CONFIG.max_activations,
            features = {
                jump = true
            }
        }
        save_license(license_data)
        return true, "License activated successfully! (" .. key_data.type .. ")"
    end
    
    return false, "Invalid key!"
end

