-- ==================== FUNCTIONS ====================
local function GetPlayerColor(player)
    if LocalPlayer.Team and player.Team then
        if LocalPlayer.Team == player.Team then
            return Config.FriendlyColor
        else
            return Config.EnemyColor
        end
    end

    return Config.DefaultColor
end

local function FormatDistance(distance)
    return string.format("%.0fm", distance)
end

local function GetHealthPercent(humanoid)
    if humanoid and humanoid.MaxHealth > 0 then
        return math.floor((humanoid.Health / humanoid.MaxHealth) * 100)
    end
    return 0
end

-- ==================== CREATE ESP ====================
local function CreateESP(player)
    if player == LocalPlayer then return end
    if ESPState.Objects[player] then return end
    if not ESPState.Active then return end

    local character = player.Character
    if not character then return end

    local root = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChildOfClass("Humanoid")

    if not root or not humanoid then return end

    -- Folder
    local folder = Instance.new("Folder")
    folder.Name = "ESP_" .. player.Name
    folder.Parent = Camera

    -- BOX
    local box = Instance.new("BoxHandleAdornment")
    box.Adornee = root
    box.Size = Vector3.new(4,6,1)
    box.Color3 = GetPlayerColor(player)
    box.AlwaysOnTop = true
    box.Transparency = Config.BoxTransparency
    box.ZIndex = 10
    box.Parent = folder

    -- BILLBOARD
    local billboard = Instance.new("BillboardGui")
    billboard.Adornee = root
    billboard.Size = UDim2.new(0,200,0,100)
    billboard.StudsOffset = Vector3.new(0,4,0)
    billboard.AlwaysOnTop = true
    billboard.Parent = folder

    local frame = Instance.new("Frame")
    frame.BackgroundTransparency = 1
    frame.Size = UDim2.new(1,0,1,0)
    frame.Parent = billboard

    -- NAME
    local name = Instance.new("TextLabel")
    name.BackgroundTransparency = 1
    name.Size = UDim2.new(1,0,0.3,0)
    name.Font = Enum.Font.GothamBold
    name.Text = player.Name
    name.TextColor3 = Color3.new(1,1,1)
    name.TextStrokeTransparency = 0
    name.TextSize = 15
    name.Parent = frame

    -- HEALTH
    local hp = Instance.new("TextLabel")
    hp.BackgroundTransparency = 1
    hp.Position = UDim2.new(0,0,0.3,0)
    hp.Size = UDim2.new(1,0,0.3,0)
    hp.Font = Enum.Font.GothamBold
    hp.Text = "HP: 100%"
    hp.TextColor3 = Color3.fromRGB(0,255,0)
    hp.TextStrokeTransparency = 0
    hp.TextSize = 14
    hp.Parent = frame

    -- DISTANCE
    local distance = Instance.new("TextLabel")
    distance.BackgroundTransparency = 1
    distance.Position = UDim2.new(0,0,0.6,0)
    distance.Size = UDim2.new(1,0,0.3,0)
    distance.Font = Enum.Font.GothamBold
    distance.Text = "0m"
    distance.TextColor3 = Color3.fromRGB(255,255,0)
    distance.TextStrokeTransparency = 0
    distance.TextSize = 14
    distance.Parent = frame

    -- LINE
    local line = Drawing.new("Line")
    line.Thickness = Config.LineThickness
    line.Transparency = 1
    line.Visible = true

    ESPState.Objects[player] = {
        Folder = folder,
        Box = box,
        Billboard = billboard,
        Name = name,
        HP = hp,
        Distance = distance,
        Line = line,
        Root = root,
        Humanoid = humanoid
    }
end

-- ==================== REMOVE ESP ====================
local function RemoveESP(player)
    local esp = ESPState.Objects[player]

    if esp then
        pcall(function()
            if esp.Folder then
                esp.Folder:Destroy()
            end

            if esp.Line then
                esp.Line:Remove()
            end
        end)

        ESPState.Objects[player] = nil
    end
end

-- ==================== UPDATE ESP ====================
local function UpdateESP()
    if not ESPState.Active then return end

    for player, esp in pairs(ESPState.Objects) do
        if player and player.Character then
            local root = player.Character:FindFirstChild("HumanoidRootPart")
            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")

            if root and humanoid then
                local color = GetPlayerColor(player)

                esp.Box.Adornee = root
                esp.Box.Color3 = color

                esp.Name.TextColor3 = color

                local hpPercent = GetHealthPercent(humanoid)
                esp.HP.Text = "HP: " .. hpPercent .. "%"

                local localRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

                if localRoot then
                    local dist = (root.Position - localRoot.Position).Magnitude
                    esp.Distance.Text = FormatDistance(dist)
                end

                local pos, visible = Camera:WorldToViewportPoint(root.Position)

                if visible then
                    esp.Line.Visible = true
                    esp.Line.Color = color

                    esp.Line.From = Vector2.new(
                        Camera.ViewportSize.X / 2,
                        Camera.ViewportSize.Y
                    )

                    esp.Line.To = Vector2.new(pos.X, pos.Y)
                else
                    esp.Line.Visible = false
                end
            end
        end
    end
end

-- ==================== PLAYER SETUP ====================
local function SetupPlayer(player)
    if player == LocalPlayer then return end

    task.spawn(function()
        repeat task.wait()
        until player.Character

        CreateESP(player)
    end)

    player.CharacterAdded:Connect(function()
        task.wait(1)

        RemoveESP(player)
        CreateESP(player)
    end)
end

-- Existing Players
for _, player in pairs(Players:GetPlayers()) do
    SetupPlayer(player)
end

-- New Players
Players.PlayerAdded:Connect(function(player)
    SetupPlayer(player)
end)

-- Remove Players
Players.PlayerRemoving:Connect(function(player)
    RemoveESP(player)
end)

-- ==================== MAIN LOOP ====================
RunService.RenderStepped:Connect(function()
    UpdateESP()
end)

-- ==================== AUTO REFRESH ====================
task.spawn(function()
    while true do
        task.wait(Config.ForceRefreshInterval)

        if ESPState.Active then
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and not ESPState.Objects[player] then
                    CreateESP(player)
                end
            end
        end
    end
end)

