                end
            end)

            card.Click.MouseButton1Click:Connect(function()
                if selectedProductId == info.ProductId then
                    selectedProductId = nil
                    selectedProductName = ""
                    buy.Active = false
                    spamBuy.Active = false

                    TweenService:Create(card.SelectedBg, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
                    TweenService:Create(card:FindFirstChild("UIStroke"), TweenInfo.new(0.2), {Transparency = 0.7, Color = RED_STROKE}):Play()
                    spawnFireBurst(fireContainer, math.random(30, 70) / 100, math.random(40, 60) / 100)
                else
                    selectedProductId = info.ProductId
                    selectedProductName = info.Name or "Unknown"
                    buy.Active = true
                    spamBuy.Active = true

                    for _, otherCard in ipairs(scroll:GetChildren()) do
                        if otherCard:IsA("Frame") and otherCard:FindFirstChild("SelectedBg") and otherCard ~= card then
                            TweenService:Create(otherCard.SelectedBg, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
                            local otherStroke = otherCard:FindFirstChild("UIStroke")
                            if otherStroke then
                                TweenService:Create(otherStroke, TweenInfo.new(0.2), {Transparency = 0.7, Color = RED_STROKE}):Play()
                            end
                        end
                    end
                    TweenService:Create(card.SelectedBg, TweenInfo.new(0.2), {BackgroundTransparency = 0.8}):Play()
                    TweenService:Create(card:FindFirstChild("UIStroke"), TweenInfo.new(0.2), {Transparency = 0.2, Color = RED_BRIGHT}):Play()
                    
                    for i = 1, 3 do
                        spawnFireBurst(fireContainer, math.random(20, 80) / 100, math.random(30, 70) / 100)
                        task.wait(0.05)
                    end
                end
            end)

            totalH = totalH + card.Size.Y.Offset + layout.Padding.Offset
        end

        scroll.CanvasSize = UDim2.new(0, 0, 0, totalH + 8)
    end)

    -- Purchase button
    buy.MouseButton1Click:Connect(function()
        if not selectedProductId then 
            getgenv().Notify({Title = 'TERJADI KESALAHAN', Content = "Pilih item terlebih dahulu!", Duration = 3})
            return 
        end
        
        TweenService:Create(buy, TweenInfo.new(0.1), {Size = UDim2.new(0.46, 0, 1, 0)}):Play()
        task.wait(0.05)
        TweenService:Create(buy, TweenInfo.new(0.1), {Size = UDim2.new(0.48, 0, 1, 0)}):Play()
        
        for i = 1, 5 do
            spawnFireBurst(fireContainer, math.random(20, 80) / 100, math.random(40, 80) / 100)
            task.wait(0.03)
        end
        
        Finished(selectedProductId)
        getgenv().Notify({Title = 'SUCCESS', Content = "Pembelian berhasil!", Duration = 3})
    end)

    -- Spam buy button
    spamBuy.MouseButton1Click:Connect(function()
        if not selectedProductId then
            getgenv().Notify({Title = 'TERJADI KESALAHAN', Content = "Pilih item terlebih dahulu!", Duration = 3})
            return
        end
        
        if spamBuyActive then
            spamBuyActive = false
            if spamBuyConnection then
                spamBuyConnection:Disconnect()
            end
            getgenv().Notify({Title = 'SPAM BUY', Content = 'DIMATIKAN', Duration = 3})
            spamBuy.Text = "🔥 SPAM BUY"
            spamBuy.BackgroundColor3 = RED_DARK
            TweenService:Create(spamBuy, TweenInfo.new(0.2), {BackgroundColor3 = RED_DARK}):Play()
        else
            spamBuy.Text = "⏹️ STOP"
            getgenv().Notify({Title = 'SPAM BUY', Content = 'AKTIF', Duration = 3})
            spamBuy.BackgroundColor3 = RED_BRIGHT
            TweenService:Create(spamBuy, TweenInfo.new(0.2), {BackgroundColor3 = RED_BRIGHT}):Play()
            startSpamBuy()
        end
    end)

    -- Animate gradient rotation
    task.spawn(function()
        local angle = 0
        while main and main.Parent do
            angle = (angle + 0.5) % 360
            bgGradient.Rotation = angle
            task.wait(0.05)
        end
    end)
    
    -- Start fire particle animation
    startFireAnimation(fireContainer)
    
    -- Update fire particles
    RunService.Heartbeat:Connect(function(dt)
        updateFireParticles(dt)
    end)

    return main
end

