-- Hover effect function with red theme
local function hover(btn, col)
	local orig = btn.BackgroundColor3
	btn.MouseEnter:Connect(function() TweenService:Create(btn, TweenInfo.new(0.16), {BackgroundColor3 = col}):Play() end)
	btn.MouseLeave:Connect(function() TweenService:Create(btn, TweenInfo.new(0.16), {BackgroundColor3 = orig}):Play() end)
end

-- Pulse animation for stroke
local function pulseStroke(stroke)
    local pulse = true
    task.spawn(function()
        while stroke and stroke.Parent do
            local targetTrans = pulse and 0.1 or 0.5
            TweenService:Create(stroke, TweenInfo.new(1, Enum.EasingStyle.Sine), {Transparency = targetTrans}):Play()
            pulse = not pulse
            task.wait(1)
        end
    end)
end

