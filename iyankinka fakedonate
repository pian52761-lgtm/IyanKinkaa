-- FIRE SPARK PARTICLE SYSTEM
-- ============================================
local fireParticles = {}
local particleContainer = nil

local function createFireParticle(parent, xPos, yPos)
    local particle = Instance.new("Frame")
    particle.Size = UDim2.new(0, math.random(2, 5), 0, math.random(2, 5))
    particle.Position = UDim2.new(xPos, 0, yPos, 0)
    particle.BackgroundColor3 = math.random(1, 3) == 1 and YELLOW_FIRE or ORANGE_FIRE
    particle.BackgroundTransparency = math.random(30, 60) / 100
    particle.BorderSizePixel = 0
    particle.Parent = parent
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = particle
    
    local speedX = (math.random() - 0.5) * 0.02
    local speedY = -math.random(3, 8) / 100
    local life = 0
    local maxLife = math.random(40, 80)
    local startSize = particle.Size
    
    table.insert(fireParticles, {
        obj = particle,
        speedX = speedX,
        speedY = speedY,
        life = life,
        maxLife = maxLife,
        startSize = startSize,
        startPos = UDim2.new(xPos, 0, yPos, 0)
    })
end

local function updateFireParticles(dt)
    for i = #fireParticles, 1, -1 do
        local p = fireParticles[i]
        if not p.obj or not p.obj.Parent then
            table.remove(fireParticles, i)
        else
            p.life = p.life + 1
            local progress = p.life / p.maxLife
            
            local newX = p.startPos.X.Scale + p.speedX * p.life
            local newY = p.startPos.Y.Scale + p.speedY * p.life
            
            p.obj.Position = UDim2.new(newX, 0, newY, 0)
            p.obj.BackgroundTransparency = 0.3 + (progress * 0.7)
            local newSizeX = p.startSize.X.Offset * (1 - progress * 0.8)
            local newSizeY = p.startSize.Y.Offset * (1 - progress * 0.8)
            p.obj.Size = UDim2.new(0, math.max(1, newSizeX), 0, math.max(1, newSizeY))
            
            if p.life >= p.maxLife or newY > 1.1 or newY < -0.1 then
                p.obj:Destroy()
                table.remove(fireParticles, i)
            end
        end
    end
end

local function spawnFireBurst(parent, centerX, centerY)
    local count = math.random(8, 15)
    for i = 1, count do
        local offsetX = (math.random() - 0.5) * 0.15
        local offsetY = (math.random() - 0.5) * 0.1
        task.spawn(function()
            createFireParticle(parent, centerX + offsetX, centerY + offsetY)
        end)
    end
end

local lastSpawn = 0
local function startFireAnimation(parent)
    task.spawn(function()
        while parent and parent.Parent do
            local now = tick()
            if now - lastSpawn > 0.15 then
                lastSpawn = now
                spawnFireBurst(parent, math.random(5, 95) / 100, math.random(10, 90) / 100)
                spawnFireBurst(parent, math.random(5, 95) / 100, math.random(10, 90) / 100)
            end
            task.wait(0.05)
        end
    end)
end

