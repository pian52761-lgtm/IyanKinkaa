-- SPIN
-- ============================================================
local function toggleSpin()
    if Config.SpinConnection then
        Config.SpinConnection:Disconnect()
        Config.SpinConnection = nil
        return false
    end

    if not HumanoidRootPart then return false end

    Config.SpinConnection = RunService.Heartbeat:Connect(function()
        HumanoidRootPart.CFrame = HumanoidRootPart.CFrame * CFrame.Angles(0, math.rad(30), 0)
    end)
    return true
end

-- ============================================================
-- SWIM
-- ============================================================
local function toggleSwim()
    if Config.SwimConnection then
        Config.SwimConnection:Disconnect()
        Config.SwimConnection = nil
        Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
        return false
    end

    Humanoid:ChangeState(Enum.HumanoidStateType.Swimming)
    Config.SwimConnection = RunService.Heartbeat:Connect(function()
        if Humanoid:GetState() ~= Enum.HumanoidStateType.Swimming then
            Humanoid:ChangeState(Enum.HumanoidStateType.Swimming)
        end
    end)
    return true
end

-- ============================================================
-- FLY
-- ============================================================
local function toggleFly()
    if Config.FlyEnabled then
        Config.FlyEnabled = false
        if Config.FlyBodyVel then Config.FlyBodyVel:Destroy() end
        if Config.FlyBodyGyro then Config.FlyBodyGyro:Destroy() end
        Humanoid.PlatformStand = false
        return false
    end

    if not HumanoidRootPart then return false end

    Config.FlyEnabled = true

    Config.FlyBodyGyro = Instance.new("BodyGyro")
    Config.FlyBodyGyro.P = 90000
    Config.FlyBodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    Config.FlyBodyGyro.CFrame = HumanoidRootPart.CFrame
    Config.FlyBodyGyro.Parent = HumanoidRootPart

    Config.FlyBodyVel = Instance.new("BodyVelocity")
    Config.FlyBodyVel.Velocity = Vector3.new(0, 0, 0)
    Config.FlyBodyVel.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    Config.FlyBodyVel.Parent = HumanoidRootPart

    Humanoid.PlatformStand = true

    task.spawn(function()
        while Config.FlyEnabled and Config.FlyBodyVel and Config.FlyBodyGyro do
            local camera = workspace.CurrentCamera
            local moveDirection = Vector3.new()

            if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                moveDirection = moveDirection + camera.CFrame.LookVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                moveDirection = moveDirection - camera.CFrame.LookVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                moveDirection = moveDirection - camera.CFrame.RightVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                moveDirection = moveDirection + camera.CFrame.RightVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                moveDirection = moveDirection + Vector3.new(0, 1, 0)
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
                moveDirection = moveDirection - Vector3.new(0, 1, 0)
            end

            Config.FlyBodyVel.Velocity = moveDirection * 50
            Config.FlyBodyGyro.CFrame = camera.CFrame
            task.wait()
        end
    end)

    return true
end

-- ============================================================
-- NOCLIP
-- ============================================================
local function toggleNoclip()
    if Config.NoclipEnabled then
        Config.NoclipEnabled = false
        if Config.NoclipConnection then
            Config.NoclipConnection:Disconnect()
        end

        for _, part in pairs(Character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
        return false
    end

    Config.NoclipEnabled = true
    Config.NoclipConnection = RunService.Stepped:Connect(function()
        for _, part in pairs(Character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end)
    return true
end

-- ============================================================
-- RAINBOW
-- ============================================================
local function toggleRainbow()
    if Config.RainbowConnection then
        Config.RainbowConnection:Disconnect()
        Config.RainbowConnection = nil

        for _, part in pairs(Character:GetDescendants()) do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                part.Color = Color3.fromRGB(163, 162, 165)
            end
        end
        return false
    end

    local hue = 0
    Config.RainbowConnection = RunService.Heartbeat:Connect(function()
        hue = (hue + 0.01) % 1
        local color = Color3.fromHSV(hue, 0.6, 0.9)

        for _, part in pairs(Character:GetDescendants()) do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                part.Color = color
            end
        end
    end)
    return true
end

-- ============================================================
-- RESPAWN AT POSITION (/RE)
-- ============================================================
local function respawnAtPosition()
    local rootPart = Character and Character:FindFirstChild("HumanoidRootPart")
    local savedCFrame = rootPart and rootPart.CFrame

    if savedCFrame then
        LocalPlayer.CharacterAdded:Once(function(newChar)
            task.wait(0.5)
            local newRoot = newChar:WaitForChild("HumanoidRootPart", 3)
            if newRoot then
                newRoot.CFrame = savedCFrame
            end
        end)
        Humanoid.Health = 0
        showNotification("/RE", "Respawning at current position...", 2)
    else
        Humanoid.Health = 0
        showNotification("/RE", "Respawning...", 2)
    end
end

