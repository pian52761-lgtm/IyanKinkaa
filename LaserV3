-- ============================================================
-- ANIMATION FUNCTIONS
-- ============================================================
local function loadAnimation(animId)
    local success, asset = pcall(function()
        return game:GetObjects("rbxassetid://" .. animId)[1]
    end)

    if not success or not asset then
        local insertService = game:GetService("InsertService")
        success, asset = pcall(function()
            return insertService:LoadAsset(animId)
        end)
    end

    if success and asset then
        local animation = asset:FindFirstChildWhichIsA("Animation")
        if animation then
            return animation
        end
    end

    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://" .. animId
    return anim
end

local function playAnimation(animId, priority, speed)
    if not Animator then
        Animator = Instance.new("Animator")
        Animator.Parent = Humanoid
    end

    local animation = loadAnimation(animId)
    if not animation then return nil end

    local track = Animator:LoadAnimation(animation)
    track.Priority = (priority == "Action4") and Enum.AnimationPriority.Action4 or Enum.AnimationPriority.Action3
    track:Play(0.1, 1, speed or Config.Speed)
    return track
end

local function stopAnimations()
    if Config.AnimTrack1 then
        pcall(function() Config.AnimTrack1:Stop(0.1) end)
        Config.AnimTrack1 = nil
    end
    if Config.AnimTrack2 then
        pcall(function() Config.AnimTrack2:Stop(0.1) end)
        Config.AnimTrack2 = nil
    end
end

-- ============================================================
-- GLITCH FUNCTIONS
-- ============================================================
local function startGlitch()
    if Config.Active then return end

    local mode = AnimationModes[Config.Mode]
    if not mode then return end

    Config.Active = true

    if mode.id1 then
        Config.AnimTrack1 = playAnimation(mode.id1, "Action4", Config.Speed)
    end
    if mode.id2 then
        Config.AnimTrack2 = playAnimation(mode.id2, "Action3", Config.Speed)
    end

    showNotification("IYANXCODE", mode.name .. " AKTIF!", 2)
end

local function stopGlitch()
    if not Config.Active then return end

    Config.Active = false
    stopAnimations()
    Humanoid:ChangeState(Enum.HumanoidStateType.Running)
    showNotification("IYANXCODE", "GLITCH DIMATIKAN", 2)
end

