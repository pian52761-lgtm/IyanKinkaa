    featuresLabel.TextSize = 10
    featuresLabel.TextColor3 = Theme.TextSecondary
    featuresLabel.TextXAlignment = Enum.TextXAlignment.Left
    featuresLabel.Parent = mainFrame

    local function createFeatureButton(text, icon, position, callback)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0.48, -6, 0, 30)
        btn.Position = position
        btn.BackgroundColor3 = Theme.Elevated
        btn.BorderSizePixel = 0
        btn.Text = icon .. " " .. text
        btn.TextColor3 = Theme.TextPrimary
        btn.Font = Enum.Font.GothamBold
        btn.TextSize = 9
        btn.Parent = mainFrame

        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

        local btnStroke = Instance.new("UIStroke", btn)
        btnStroke.Color = Theme.Primary
        btnStroke.Thickness = 1
        btnStroke.Transparency = 0.7

        btn.MouseEnter:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.2), { BackgroundColor3 = Theme.Surface }):Play()
            btnStroke.Transparency = 0.3
        end)

        btn.MouseLeave:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.2), { BackgroundColor3 = Theme.Elevated }):Play()
            btnStroke.Transparency = 0.7
        end)

        local active = false
        btn.MouseButton1Click:Connect(function()
            active = callback()
            if active then
                btn.BackgroundColor3 = Theme.Success
                btn.TextColor3 = Color3.fromRGB(255, 255, 255)
                btnStroke.Color = Theme.Success
                btnStroke.Transparency = 0
            else
                btn.BackgroundColor3 = Theme.Elevated
                btn.TextColor3 = Theme.TextPrimary
                btnStroke.Color = Theme.Primary
                btnStroke.Transparency = 0.7
            end
        end)

        return btn
    end

    createFeatureButton("SPIN", "🔄", UDim2.new(0, 10, 0, 240), toggleSpin)
    createFeatureButton("SWIM", "🏊", UDim2.new(0.52, 0, 0, 240), toggleSwim)
    createFeatureButton("FLY", "🚀", UDim2.new(0, 10, 0, 274), toggleFly)
    createFeatureButton("/RE", "♻️", UDim2.new(0.52, 0, 0, 274), function() respawnAtPosition(); return true end)
    createFeatureButton("NOCLIP", "👻", UDim2.new(0, 10, 0, 308), toggleNoclip)
    createFeatureButton("RAINBOW", "🌈", UDim2.new(0.52, 0, 0, 308), toggleRainbow)

    -- Footer
    local footer = Instance.new("Frame")
    footer.Size = UDim2.new(1, -20, 0, 22)
    footer.Position = UDim2.new(0, 10, 0, 332)
    footer.BackgroundColor3 = Theme.Surface
    footer.BorderSizePixel = 0
    footer.Parent = mainFrame
    Instance.new("UICorner", footer).CornerRadius = UDim.new(0, 6)

    local footerText = Instance.new("TextLabel")
    footerText.Size = UDim2.new(1, 0, 1, 0)
    footerText.BackgroundTransparency = 1
    footerText.Text = "IYANXCODE — FREE VERSION"
    footerText.Font = Enum.Font.GothamMedium
    footerText.TextSize = 8
    footerText.TextColor3 = Theme.TextMuted
    footerText.Parent = footer

    -- Mini button click to restore
    miniButton.MouseButton1Click:Connect(function()
        mainFrame.Visible = true
        miniButton.Visible = false
        Config.Minimized = false
        TweenService:Create(mainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
            Size = UDim2.new(0, 280, 0, 360)
        }):Play()
    end)

    -- Character respawn handler
    LocalPlayer.CharacterAdded:Connect(function(newChar)
        Character = newChar
        Humanoid = Character:WaitForChild("Humanoid")
        Animator = Humanoid:WaitForChild("Animator")
        HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")

        if Config.Active then
            task.wait(1)
            startGlitch()
        end
    end)

    return screenGui
end

