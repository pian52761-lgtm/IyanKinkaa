local keyFileName = "YTTA_Key.txt"

local function saveKey(key)
    pcall(function() writefile(keyFileName, key) end)
end

local function loadKey()
    local success, content = pcall(function()
        if isfile(keyFileName) then return readfile(keyFileName) end
        return nil
    end)
    return success and content or nil
end

local function clearKey()
    pcall(function() delfile(keyFileName) end)
end

local ValidKeys = {}

local function loadKeysFromGitHub()
    local success, response = pcall(function()
        return game:HttpGet(Config.KeysUrl)
    end)
    if success and response then
        local count = 0
        for line in response:gmatch("[^\r\n]+") do
            local key = line:gsub("%s+", "")
            if key ~= "" then
                ValidKeys[key] = true
                count = count + 1
            end
        end
        print("✅ Loaded " .. count .. " valid keys from GitHub")
        return true
    else
        ValidKeys = { ["IYANGANTENG"] = true }
        print("⚠️ Using fallback keys (GitHub unavailable)")
        return false
    end
end

loadKeysFromGitHub()

local function validateKey(key)
    if not key or key == "" then return false end
    return ValidKeys[key] == true
end

